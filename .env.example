# Synapse Council v2.0 - Environment Configuration Template
# Copia este archivo como .env y reemplaza los valores CHANGEME

NODE_ROLE=MASTER
PORT=8000
HOST=0.0.0.0

# --- Worker Configuration ---
WORKER_OLLAMA_PORT=11434
WORKER_LM_STUDIO_PORT=1234
WORKER_JAN_PORT=1337

# --- API Keys (rellenar si se tienen) ---
OPENROUTER_API_KEY=sk-or-v1-CHANGEME
OPENROUTER_ENABLED=true

# --- Google Gemini API (Free Tier) ---
GEMINI_API_KEY=AIzaSy-CHANGEME
GEMINI_ENABLED=true

# --- Groq API (Free Tier) ---
GROQ_API_KEY=gsk_CHANGEME
GROQ_ENABLED=true

# --- DeepSeek API ---
DEEPSEEK_API_KEY=sk-CHANGEME
DEEPSEEK_ENABLED=true

# --- Supabase (Opcional, para elevación a nube) ---
SUPABASE_URL=https://CHANGEME.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.CHANGEME
SUPABASE_ENABLED=true

# --- Features del Master ---
WEB_AGENT_ENABLED=true
MAX_CONCURRENT_SESSIONS=3

# --- Discovery P2P ---
DISCOVERY_PORT=54321
DISCOVERY_INTERVAL=5

# --- Logging ---
LOG_LEVEL=INFO

# --- Feature Flags (Mejoras v2.1) ---
INTERVENTION_TAXONOMY_ENABLED=true
QUALITY_MONITOR_ENABLED=true
AGENT_REPUTATION_ENABLED=true
HYBRID_MEMORY_V2_ENABLED=true

# --- Model Timeouts (segundos por modelo) ---
# Patrones se buscan con substring match (mas largo primero)
# Default: OLLAMA_TIMEOUT_SECONDS=600 para locales, OPENROUTER_TIMEOUT_SECONDS=90 para cloud
MODEL_TIMEOUTS='{"llama3.1:70b": 300, "llama3:70b": 300, "llama3.1:405b": 600, "deepseek-r1:32b": 300, "deepseek-r1:70b": 600, "mistral-large": 180, "mixtral:8x22b": 300, "qwen2.5:72b": 300, "70b": 300, "405b": 600}'
