# --- Supabase (Opcional, para elevación a nube) ---
SUPABASE_URL=https://CHANGEME.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.CHANGEME
