# ═══════════════════════════════════════════════════════════════
# SYNAPSE COUNCIL v2.0 — Variables de Entorno
# ═══════════════════════════════════════════════════════════════

# ─── Rol del Nodo ─────────────────────────────────────────────
# MASTER: Orquestador, UI, conexiones nube
# WORKER: Solo inferencia local (Ollama, LM Studio, Jan)
NODE_ROLE=MASTER

# IP del PC B cuando NODE_ROLE=MASTER
WORKER_HOST=192.168.1.100
WORKER_OLLAMA_PORT=11434
WORKER_LM_STUDIO_PORT=1234
WORKER_JAN_PORT=1337

# ─── Base de Datos Local ──────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/synapse.db

# ─── Ollama ───────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT_SECONDS=120
OLLAMA_MAX_RETRIES=2
OLLAMA_KEEP_ALIVE=0

# ─── LM Studio ────────────────────────────────────────────────
LM_STUDIO_BASE_URL=http://localhost:1234
LM_STUDIO_TIMEOUT_SECONDS=120
LM_STUDIO_MAX_RETRIES=2
LM_STUDIO_KEEP_ALIVE=0

# ─── Jan.ai ───────────────────────────────────────────────────
JAN_BASE_URL=http://localhost:1337
JAN_TIMEOUT_SECONDS=120
JAN_MAX_RETRIES=2
JAN_KEEP_ALIVE=0

# ─── OpenRouter ───────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-tu-api-key-aqui
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TIMEOUT_SECONDS=90
OPENROUTER_MAX_RETRIES=2
OPENROUTER_HTTP_REFERER=http://localhost:3000
OPENROUTER_APP_NAME=SynapseCouncil

# ─── Agente Web (Playwright) ──────────────────────────────────
WEB_AGENT_ENABLED=true
WEB_AGENT_BROWSER=chromium
WEB_AGENT_HEADLESS=true
WEB_AGENT_TIMEOUT_SECONDS=120
WEB_AGENT_SITES=chat.openai.com,claude.ai,gemini.google.com
WEB_AGENT_SESSION_DIR=./data/browser_sessions

# ─── Supabase (memoria-oscar) ─────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_ENABLED=true
SUPABASE_PROJECT=memoria-oscar

# ─── Sistema de Reputación ────────────────────────────────────
AGENT_REPUTATION_ENABLED=true
REPUTATION_EMA_ALPHA=0.3
REPUTATION_MIN_DEBATES_FOR_WEIGHT=3

# ─── Motor ────────────────────────────────────────────────────
MAX_CONCURRENT_SESSIONS=3
DEFAULT_MAX_ROUNDS=3
DEFAULT_COST_LIMIT_USD=1.00
AUTO_ELEVATION_ENABLED=true
TRIBUNAL_MAX_ITERATIONS=3

# ─── Servidor ─────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
LOG_LEVEL=INFO

# ─── Frontend ─────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_WS_BASE_URL=ws://localhost:8000
