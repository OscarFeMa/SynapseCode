# ══════════════════════════════════════════════
# SynapseCode v2.8 — .gitignore
# ══════════════════════════════════════════════

# ── Python ───────────────────────────────────
.venv/
venv/
__pycache__/
*.pyc
*.pyo
*.pyd
*.so
.Python
*.egg-info/
dist/
build/
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# ── Entorno y Secretos ───────────────────────
.env
.env.local
.env.*.local
*.key
*.pem
*.p12
*.pfx

# ── Acceso remoto — NUNCA versionar ──────────
*.rdp
*.vnc
synapse_workers.json
synapse_workers_*.json

# ── Base de datos ────────────────────────────
data/*.db
data/*.db-journal
data/*.db-wal
data/*.db-shm

# ── Datos generados en runtime ───────────────
data/debates/*.md
data/debates/*.json
data/reports/*.html
data/reports/*.pdf

# ── Browser sessions (Playwright) ────────────
data/browser_sessions/
*.cookie

# ── Logs ─────────────────────────────────────
logs/
*.log

# ── Frontend ─────────────────────────────────
node_modules/
.pnpm-store/
frontend/dist/
frontend/.vite/
desktop/node_modules/
desktop/dist/
desktop/frontend/dist/

# ── IDE ──────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ───────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── CI artifacts ─────────────────────────────
test_results*.xml
